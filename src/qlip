                                            sticky="w", pady=4)

    row += 1
    cursor_var = tk.BooleanVar(value=cfg["include_cursor"])
    ttk.Checkbutton(sf, text="Include cursor in screenshots",
                    variable=cursor_var).grid(row=row, column=0, columnspan=3,
