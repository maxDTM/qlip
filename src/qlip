    spacer.pack(fill="both", expand=True)

    ttk.Label(usage_frame, text=f"Backend: {session_label}",
              style="Backend.TLabel").pack(anchor="w")

    # ── Settings tab ─────────────────────────────────────────────
    sf = ttk.Frame(notebook, padding=20)
