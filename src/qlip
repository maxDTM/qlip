    row += 1
    preview_var = tk.StringVar()

    def update_preview(*_):
        now = datetime.now()
        try:
            rendered = now.strftime(fn_var.get())
        except Exception:
            rendered = "(invalid)"
        preview_var.set(f"{rendered}.{ft_var.get().lstrip('.')}")

    fn_var.trace_add("write", update_preview)
    ft_var.trace_add("write", update_preview)
    update_preview()

    ttk.Label(sf, textvariable=preview_var,
              font=("monospace", 9), style="Dim.TLabel").grid(
        row=row, column=0, columnspan=3, sticky="w", pady=(2, 8))

