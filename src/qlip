    ttk.Label(sf, text="Configuration",
              style="Header.TLabel").grid(row=0, column=0, columnspan=3,
                                           sticky="w", pady=(0, 12))

    row = 1
    ttk.Label(sf, text="Save location:").grid(row=row, column=0, sticky="w", pady=6)
    dir_var = tk.StringVar(value=cfg["save_dir"])
    ttk.Entry(sf, textvariable=dir_var, width=32).grid(row=row, column=1, pady=6, padx=(8, 4))

    def browse_dir():
