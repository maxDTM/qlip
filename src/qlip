    ttk.Button(sf, text="Browse", command=browse_dir).grid(row=row, column=2, pady=6, padx=4)

    row += 1
    ask_var = tk.BooleanVar(value=cfg["ask_save_location"])
    ttk.Checkbutton(sf, text="Ask where to save each screenshot",
